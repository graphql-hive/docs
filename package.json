{
  "name": "@scriptorium/monorepo",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*"
  ],
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@fumadocs/cli": "^1.2.2",
    "@hasparus/eslint-config": "2.0.12",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "latest",
    "jiti": "2.6.1",
    "prettier": "3.7.4",
    "turbo": "2.7.4",
    "typescript": "5.9.3"
  },
  "patchedDependencies": {
    "mermaid-isomorphic@3.0.4": "patches/mermaid-isomorphic@3.0.4.patch"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "fumadocs-ui": "^16.4.7",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "tailwind-merge": "^3.4.0"
  }
}
