{
  "name": "docs",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "vite build",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "start": "bun .output/server/index.mjs",
    "typecheck": "bun --bun fumadocs-mdx && bun --bun tsc --noEmit",
    "postinstall": "bun --bun fumadocs-mdx && bun playwright install chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "bunx playwright test",
    "test:ui": "bunx playwright test --ui",
    "test:headed": "bunx playwright test --headed",
    "test:bun": "bun test",
    "test": "bun test:e2e && bun test:bun",
    "deploy": "wrangler deploy",
    "versions-upload": "wrangler versions upload"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@hive/design-system": "workspace:*",
    "@sparticuz/chromium": "143.0.4",
    "@tanstack/devtools-vite": "0.4.1",
    "@tanstack/react-router": "1.147.1",
    "@tanstack/react-router-devtools": "1.147.1",
    "@tanstack/react-start": "1.147.1",
    "@unpic/react": "1.0.2",
    "arktype": "^2.1.29",
    "class-variance-authority": "0.7.1",
    "fumadocs-core": "16.4.7",
    "fumadocs-mdx": "14.2.5",
    "fumadocs-twoslash": "3.1.12",
    "fumadocs-ui": "16.4.7",
    "lucide-react": "0.562.0",
    "nitro": "npm:nitro-nightly@latest",
    "playwright": "1.57.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-mermaid": "3.0.0",
    "tailwind-merge": "3.4.0",
    "twoslash": "0.3.6",
    "vite": "7.3.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-links": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@storybook/theming": "^8.6.12",
    "next-themes": "^0.4.6",
    "storybook": "^8.6.12",
    "storybook-dark-mode": "^4.0.2",
    "@playwright/test": "1.57.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/mdx": "2.0.13",
    "@types/node": "25.0.5",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "vite-plugin-svgr": "4.5.0",
    "vite-tsconfig-paths": "6.0.4"
  }
}
