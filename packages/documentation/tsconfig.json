{
  "extends": "../../tsconfig.json",
  "include": ["src/**/*.ts", "src/**/*.tsx", ".source/**/*.ts", "*.config.ts"],
  "compilerOptions": {
    "types": ["vite/client", "bun"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@hive/design-system/*": ["../design-system/src/*"],
      "fumadocs-mdx:collections/*": ["./.source/*"]
    },
    "jsx": "react-jsx"
  }
}
