{
  "extends": "../../tsconfig.json",
  "include": ["src/**/*.ts", "src/**/*.tsx", ".source/**/*.ts", "*.ts"],
  "compilerOptions": {
    "types": ["vite/client", "bun"],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "fumadocs-mdx:collections/*": ["./.source/*"]
    },
    "jsx": "react-jsx",
    "composite": true,
    "noEmit": false,
    "outDir": "dist"
  }
}
